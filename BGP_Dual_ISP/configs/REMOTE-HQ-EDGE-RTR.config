
hostname REMOTE-HQ-EDGE-RTR
!
ip prefix-list HQ-LAN-ONLY seq 10 permit 10.10.10.0/24
ip prefix-list REMOTE-HQ-LAN-ONLY seq 10 permit 10.20.20.0/24
!
interface eth1
 description REMOTE-HQ-LAN
 ip address 10.20.20.1/24
exit
!
interface eth8
 description ISP-A-CIRCUIT-TO-HQ
 ip address 172.16.1.2/30
exit
!
interface eth9
 description ISP-B-CIRCUIT-TO-HQ
 ip address 172.16.2.2/30
exit
!
router bgp 65020
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 172.16.1.1 remote-as 65010
 neighbor 172.16.1.1 description HQ-EDGE-VIA-ISP1
 neighbor 172.16.1.1 bfd
 neighbor 172.16.1.1 timers 3 9
 neighbor 172.16.2.1 remote-as 65010
 neighbor 172.16.2.1 description HQ-EDGE-VIA-ISP2
 neighbor 172.16.2.1 bfd
 neighbor 172.16.2.1 timers 3 9
 !
 address-family ipv4 unicast
  network 10.20.20.0/24
  neighbor 172.16.1.1 activate
  neighbor 172.16.1.1 soft-reconfiguration inbound
  neighbor 172.16.1.1 prefix-list HQ-LAN-ONLY in
  neighbor 172.16.1.1 prefix-list REMOTE-HQ-LAN-ONLY out
  neighbor 172.16.2.1 activate
  neighbor 172.16.2.1 soft-reconfiguration inbound
  neighbor 172.16.2.1 prefix-list HQ-LAN-ONLY in
  neighbor 172.16.2.1 prefix-list REMOTE-HQ-LAN-ONLY out
  maximum-paths 2
 exit-address-family
exit
!
end